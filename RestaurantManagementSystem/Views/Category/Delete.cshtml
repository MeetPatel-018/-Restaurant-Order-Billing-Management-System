@model RestaurantManagementSystem.Models.Category
@{
    ViewData["Title"] = "Delete Category";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-trash"></i> Delete Category
        </h1>
        <a href="/Category" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card">
        <div class="card-header bg-danger text-white">
            <i class="fas fa-exclamation-triangle"></i> Confirm Deletion
        </div>
        <div class="card-body">
            <h3>Are you sure you want to delete this category?</h3>
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-circle"></i>
                <strong>Warning:</strong> This action cannot be undone.
            </div>

            <div class="row">
                <div class="col-md-6">
                    <table class="table table-borderless">
                        <tr>
                            <td><strong>Category ID:</strong></td>
                            <td>@Model.CategoryID</td>
                        </tr>
                        <tr>
                            <td><strong>Category Name:</strong></td>
                            <td>@Model.CategoryName</td>
                        </tr>
                        <tr>
                            <td><strong>Menu Items Count:</strong></td>
                            <td>
                                <span class="badge bg-info">
                                    @(Model.MenuItems?.Count ?? 0) items
                                </span>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            @if (Model.MenuItems != null && Model.MenuItems.Any())
            {
                <div class="alert alert-danger mt-3">
                    <i class="fas fa-ban"></i>
                    <strong>This category cannot be deleted because it contains menu items.</strong>
                    <br>Please remove or reassign the menu items first.
                </div>
                <div class="mt-3">
                    <a href="/Category" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
            }
            else
            {
                <form asp-action="DeleteConfirmed" method="post">
                    <input type="hidden" asp-for="CategoryID" />
                    <div class="mt-3">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Delete Category
                        </button>
                        <a href="/Category" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                </form>
            }
        </div>
    </div>
</div>
