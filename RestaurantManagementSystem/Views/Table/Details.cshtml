@model RestaurantManagementSystem.Models.Table
@{
    ViewData["Title"] = "Table Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-info-circle"></i> Table Details
        </h1>
        <div>
            <a href="/Table/Edit/@Model.TableID" class="btn btn-warning">
                <i class="fas fa-edit"></i> Edit
            </a>
            <a href="/Table" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-chair"></i> Table Information
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tr>
                            <td style="width: 150px;"><strong>Table ID:</strong></td>
                            <td>@Model.TableID</td>
                        </tr>
                        <tr>
                            <td><strong>Table Number:</strong></td>
                            <td><h4>@Model.TableNumber</h4></td>
                        </tr>
                        <tr>
                            <td><strong>Capacity:</strong></td>
                            <td>
                                <span class="badge bg-info">@Model.Capacity seats</span>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Status:</strong></td>
                            <td>
                                <span class="status-badge status-@Model.Status.ToLower()">
                                    @Model.Status
                                </span>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            @if (Model.Orders != null && Model.Orders.Any())
            {
                <div class="card mt-4">
                    <div class="card-header">
                        <i class="fas fa-receipt"></i> Recent Orders
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Order ID</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                        <th>Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.Orders.OrderByDescending(o => o.OrderDate).Take(5))
                                    {
                                        <tr>
                                            <td>#@order.OrderID</td>
                                            <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                                            <td>
                                                <span class="status-badge status-@order.OrderStatus.ToLower()">
                                                    @order.OrderStatus
                                                </span>
                                            </td>
                                            <td>@order.TotalAmount.ToString("C")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-chart-pie"></i> Quick Actions
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="/Table/Edit/@Model.TableID" class="btn btn-warning">
                            <i class="fas fa-edit"></i> Edit Table
                        </a>
                        <a href="/Table/ToggleStatus/@Model.TableID" class="btn btn-info">
                            <i class="fas fa-toggle-on"></i> Toggle Status
                        </a>
                        <a href="/Table/Delete/@Model.TableID" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Delete Table
                        </a>
                    </div>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header">
                    <i class="fas fa-info"></i> Table Status
                </div>
                <div class="card-body text-center">
                    @if (Model.Status == "Available")
                    {
                        <i class="fas fa-check-circle fa-3x text-success mb-2"></i>
                        <h5 class="text-success">Available</h5>
                        <p class="text-muted">This table is ready for customers</p>
                    }
                    else
                    {
                        <i class="fas fa-users fa-3x text-danger mb-2"></i>
                        <h5 class="text-danger">Occupied</h5>
                        <p class="text-muted">This table is currently in use</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
