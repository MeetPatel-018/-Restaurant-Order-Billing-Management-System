@model RestaurantManagementSystem.Models.Table
@{
    ViewData["Title"] = "Delete Table";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-trash"></i> Delete Table
        </h1>
        <a href="/Table" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card">
        <div class="card-header bg-danger text-white">
            <i class="fas fa-exclamation-triangle"></i> Confirm Deletion
        </div>
        <div class="card-body">
            <h3>Are you sure you want to delete this table?</h3>
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-circle"></i>
                <strong>Warning:</strong> This action cannot be undone.
            </div>

            <div class="row">
                <div class="col-md-6">
                    <table class="table table-borderless">
                        <tr>
                            <td style="width: 150px;"><strong>Table ID:</strong></td>
                            <td>@Model.TableID</td>
                        </tr>
                        <tr>
                            <td><strong>Table Number:</strong></td>
                            <td>@Model.TableNumber</td>
                        </tr>
                        <tr>
                            <td><strong>Capacity:</strong></td>
                            <td>@Model.Capacity seats</td>
                        </tr>
                        <tr>
                            <td><strong>Status:</strong></td>
                            <td>
                                <span class="status-badge status-@Model.Status.ToLower()">
                                    @Model.Status
                                </span>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            @if (Model.Orders != null && Model.Orders.Any())
            {
                <div class="alert alert-danger mt-3">
                    <i class="fas fa-ban"></i>
                    <strong>This table cannot be deleted because it has associated orders.</strong>
                    <br>Please delete or reassign the orders first.
                </div>
                <div class="mt-3">
                    <a href="/Table" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
            }
            else
            {
                <form asp-action="DeleteConfirmed" method="post">
                    <input type="hidden" asp-for="TableID" />
                    <div class="mt-3">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Delete Table
                        </button>
                        <a href="/Table" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                </form>
            }
        </div>
    </div>
</div>
