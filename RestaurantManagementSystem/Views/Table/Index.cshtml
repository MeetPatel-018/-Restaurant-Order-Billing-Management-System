@model IEnumerable<RestaurantManagementSystem.Models.Table>
@{
    ViewData["Title"] = "Tables";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-chair"></i> Table Management
        </h1>
        <a href="@Url.Action("Create", "Table")" class="btn btn-teal">
            <i class="fas fa-plus"></i> Add New Table
        </a>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h4>@(Model?.Count(t => t.Status == "Available") ?? 0)</h4>
                    <p class="mb-0">Available Tables</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body text-center">
                    <h4>@Model.Count(t => t.Status == "Occupied")</h4>
                    <p class="mb-0">Occupied Tables</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h4>@Model.Sum(t => t.Capacity)</h4>
                    <p class="mb-0">Total Capacity</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body text-center">
                    <h4>@Model.Count()</h4>
                    <p class="mb-0">Total Tables</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <i class="fas fa-list"></i> All Tables
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Table ID</th>
                                <th>Table Number</th>
                                <th>Capacity</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var table in Model)
                            {
                                <tr>
                                    <td>@table.TableID</td>
                                    <td>
                                        <strong>@table.TableNumber</strong>
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@table.Capacity seats</span>
                                    </td>
                                    <td>
                                        <span class="status-badge status-@table.Status.ToLower()">
                                            @table.Status
                                        </span>
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="/Table/Details/@table.TableID" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="/Table/Edit/@table.TableID" class="btn btn-sm btn-outline-warning">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="/Table/Delete/@table.TableID" class="btn btn-sm btn-outline-danger">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="fas fa-chair fa-3x text-muted mb-3"></i>
                    <p class="text-muted">No tables found.</p>
                    <a href="/Table/Create" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Add First Table
                    </a>
                </div>
            }
        </div>
    </div>
</div>
