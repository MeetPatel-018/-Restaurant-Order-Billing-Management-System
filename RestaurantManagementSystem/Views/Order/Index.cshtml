@model IEnumerable<RestaurantManagementSystem.Models.Order>
@{
    ViewData["Title"] = "Orders";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-receipt"></i> Order Management
        </h1>
        <a href="@Url.Action("Create", "Order")" class="btn btn-teal">
            <i class="fas fa-plus"></i> Create New Order
        </a>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h4>@(Model?.Count() ?? 0)</h4>
                    <p class="mb-0">Total Orders</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body text-center">
                    <h4>@Model?.Count(o => o.OrderStatus == "Pending")</h4>
                    <p class="mb-0">Pending Orders</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h4>@Model?.Count(o => o.OrderStatus == "Completed")</h4>
                    <p class="mb-0">Completed Orders</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body text-center">
                    <h4>@Model?.Count(o => o.OrderStatus == "Cancelled")</h4>
                    <p class="mb-0">Cancelled Orders</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <i class="fas fa-list"></i> All Orders
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Table</th>
                                <th>Date & Time</th>
                                <th>Status</th>
                                <th>Items</th>
                                <th>Total Amount</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>#@order.OrderID</strong>
                                    </td>
                                    <td>@order.Table?.TableNumber</td>
                                    <td>@order.OrderDate.ToString("dd MMM yyyy<br/>hh:mm tt")</td>
                                    <td>
                                        <span class="status-badge status-@order.OrderStatus.ToLower()">
                                            @order.OrderStatus
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary" onclick="toggleOrderItems(@order.OrderID)">
                                            <i class="fas fa-list"></i> @order.OrderItems.Count items
                                        </button>
                                    </td>
                                    <td><strong>@order.TotalAmount.ToString("C")</strong></td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="/Order/Details/@order.OrderID" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            @if (order.OrderStatus == "Pending")
                                            {
                                                <a href="/Billing/GenerateBill?orderId=@order.OrderID" class="btn btn-sm btn-outline-success">
                                                    <i class="fas fa-file-invoice"></i>
                                                </a>
                                            }
                                            <a href="/Order/Delete/@order.OrderID" class="btn btn-sm btn-outline-danger">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                <tr id="orderItems-@order.OrderID" style="display: none;">
                                    <td colspan="7">
                                        <div class="p-3 bg-light">
                                            <h6>Order Items:</h6>
                                            <table class="table table-sm mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>Item</th>
                                                        <th>Quantity</th>
                                                        <th>Price</th>
                                                        <th>Subtotal</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var item in order.OrderItems)
                                                    {
                                                        <tr>
                                                            <td>@item.MenuItem?.ItemName</td>
                                                            <td>@item.Quantity</td>
                                                            <td>@item.Price.ToString("C")</td>
                                                            <td>@item.SubTotal.ToString("C")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="fas fa-receipt fa-3x text-muted mb-3"></i>
                    <p class="text-muted">No orders found.</p>
                    <a href="/Order/Create" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Create First Order
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleOrderItems(orderId) {
            var row = document.getElementById('orderItems-' + orderId);
            if (row.style.display === 'none') {
                row.style.display = 'table-row';
            } else {
                row.style.display = 'none';
            }
        }
    </script>
}
