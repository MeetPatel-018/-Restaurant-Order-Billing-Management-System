@model RestaurantManagementSystem.Models.OrderViewModel
@{
    ViewData["Title"] = "Create Order";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-plus"></i> Create Order
        </h1>
        <a href="/Order" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card">
        <div class="card-header">
            <i class="fas fa-shopping-cart"></i> Order Details
        </div>
        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                
                <div class="row">
                    <div class="col-md-12">
                        <div class="mb-3">
                            <label asp-for="TableID" class="form-label">Table</label>
                            <select asp-for="TableID" class="form-control" required>
                                <option value="">-- Select Table --</option>
                                @foreach (var table in Model.AvailableTables)
                                {
                                    <option value="@table.TableID">@table.TableNumber (@table.Capacity seats)</option>
                                }
                            </select>
                            <span asp-validation-for="TableID" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <h4><i class="fas fa-hamburger"></i> Menu Items</h4>
                        @if (Model.AvailableMenuItems != null && Model.AvailableMenuItems.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-striped">
                                    <thead>
                                        <tr>
                                            <th>Select</th>
                                            <th>Item Name</th>
                                            <th>Category</th>
                                            <th>Price</th>
                                            <th>Quantity</th>
                                            <th>Subtotal</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            var index = 0;
                                            foreach (var item in Model.AvailableMenuItems)
                                            {
                                                <tr>
                                                    <td>
                                                        <input type="checkbox" name="ItemSelected[@item.ItemID]" value="@item.ItemID" id="item_@item.ItemID"/>
                                                    </td>
                                                    <td>@item.ItemName</td>
                                                    <td>@item.CategoryName</td>
                                                    <td>@item.Price.ToString("C")</td>
                                                    <td>
                                                        <input type="number" name="Quantities[@item.ItemID]" class="form-control qty-input" min="0" max="99" value="0" data-price="@item.Price" id="qty_@item.ItemID"/>
                                                    </td>
                                                    <td id="subtotal_@item.ItemID">₹0.00</td>
                                                </tr>
                                                index++;
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                            
                            <div class="mt-3">
                                <h5>Order Total: <span id="orderTotal">₹0.00</span></h5>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle"></i> No menu items available.
                            </div>
                        }
                    </div>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Create Order
                    </button>
                    <a href="/Order" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        console.log("Order Create page loaded");
        console.log("Available menu items:", @Json.Serialize(Model.AvailableMenuItems));
        console.log("Available tables:", @Json.Serialize(Model.AvailableTables));
        
        document.querySelector('form').addEventListener('submit', function(e) {
            console.log("Order form submit button clicked");
            console.log("Form data before submit:");
            
            const formData = new FormData(this);
            for (let [key, value] of formData.entries()) {
                console.log(`${key}: ${value}`);
            }
            
            // Check form validation
            const tableId = document.querySelector('select[name="TableID"]').value;
            console.log(`TableID: ${tableId}`);
            
            if (!tableId) {
                console.log("ERROR: No table selected");
                e.preventDefault();
                return;
            }
            
            // Check if any items have quantities
            let hasItems = false;
            const quantityInputs = document.querySelectorAll('.qty-input');
            quantityInputs.forEach(input => {
                const quantity = parseInt(input.value) || 0;
                console.log(`Item ${input.dataset.price}, Quantity: ${quantity}`);
                if (quantity > 0) {
                    hasItems = true;
                }
            });
            
            if (!hasItems) {
                console.log("ERROR: No items selected");
                e.preventDefault();
            } else {
                console.log("Form validation passed - submitting");
            }
        });
        
        // Original quantity update function
        document.addEventListener('DOMContentLoaded', function() {
            console.log("DOM loaded - setting up quantity listeners");
            const quantityInputs = document.querySelectorAll('.qty-input');
            const orderTotalElement = document.getElementById('orderTotal');
            
            quantityInputs.forEach(input => {
                input.addEventListener('input', updateSubtotal);
            });
            
            function updateSubtotal() {
                let total = 0;
                
                quantityInputs.forEach(input => {
                    const price = parseFloat(input.dataset.price);
                    const quantity = parseInt(input.value) || 0;
                    const subtotalElement = document.getElementById('subtotal_' + input.id.split('_')[1]);
                    
                    if (subtotalElement) {
                        const subtotal = price * quantity;
                        subtotalElement.textContent = '₹' + subtotal.toFixed(2);
                        total += subtotal;
                    }
                });
                
                if (orderTotalElement) {
                    orderTotalElement.textContent = '₹' + total.toFixed(2);
                }
            }
        });
        
        // Set quantity to 1 when checkbox is checked
        const checkboxes = document.querySelectorAll('input[name^="ItemSelected"]');
        
        checkboxes.forEach(function(checkbox) {
            checkbox.addEventListener('change', function() {
                const itemId = this.value;
                const qtyInput = document.getElementById('qty_' + itemId);
                
                if (this.checked) {
                    qtyInput.value = 1;
                    qtyInput.dispatchEvent(new Event('input'));
                } else {
                    qtyInput.value = 0;
                    qtyInput.dispatchEvent(new Event('input'));
                }
            });
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
