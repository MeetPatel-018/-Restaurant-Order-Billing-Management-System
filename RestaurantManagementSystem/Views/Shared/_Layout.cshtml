<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Restaurant Management System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar" aria-label="Main Navigation">
            <div class="sidebar-header">
                <div class="logo-icon">
                    <i class="fas fa-utensils" aria-hidden="true"></i>
                </div>
                <h3>Restaurant Manager</h3>
            </div>

            <ul class="list-unstyled components">
                <li class="active">
                    <a href="@Url.Action("Index", "Admin")">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a href="#menuSubmenu" data-bs-toggle="collapse" aria-expanded="false" class="dropdown-toggle">
                        <i class="fas fa-hamburger"></i> Menu Management
                    </a>
                    <ul class="collapse list-unstyled" id="menuSubmenu">
                        <li><a href="@Url.Action("Index", "Category")">Categories</a></li>
                        <li><a href="@Url.Action("Index", "Menu")">Menu Items</a></li>
                    </ul>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Table")">
                        <i class="fas fa-chair"></i> Table Management
                    </a>
                </li>
                <li>
                    <a href="#orderSubmenu" data-bs-toggle="collapse" aria-expanded="false" class="dropdown-toggle">
                        <i class="fas fa-receipt"></i> Order Management
                    </a>
                    <ul class="collapse list-unstyled" id="orderSubmenu">
                        <li><a href="@Url.Action("Index", "Order")">Orders</a></li>
                        <li><a href="@Url.Action("Create", "Order")">Create Order</a></li>
                    </ul>
                </li>
                <li>
                    <a href="#billingSubmenu" data-bs-toggle="collapse" aria-expanded="false" class="dropdown-toggle">
                        <i class="fas fa-file-invoice-dollar"></i> Billing
                    </a>
                    <ul class="collapse list-unstyled" id="billingSubmenu">
                        <li><a href="@Url.Action("Index", "Billing")">Bills</a></li>
                    </ul>
                </li>
            </ul>
        </nav>

        <!-- Page Content -->
        <div id="content">
            <nav class="navbar navbar-expand-lg navbar-light bg-light" aria-label="Page Header">
                <div class="container-fluid">
                    <div class="ms-auto">
                        <span class="navbar-text">
                            <i class="fas fa-clock"></i> @DateTime.Now.ToString("dd MMM yyyy hh:mm tt")
                        </span>
                    </div>
                </div>
            </nav>

            <main class="flex-grow-1 p-4">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle"></i> @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function () {
            // Set active menu item
            var currentPath = window.location.pathname;
            if (currentPath.includes('/Admin') || currentPath === '/') {
                $('.list-unstyled li:first-child').addClass('active');
            } else if (currentPath.includes('/Category') || currentPath.includes('/Menu')) {
                $('[href="#menuSubmenu"]').parent().addClass('active');
            } else if (currentPath.includes('/Table')) {
                $('[href="@Url.Action("Index", "Table")"]').parent().addClass('active');
            } else if (currentPath.includes('/Order')) {
                $('[href="#orderSubmenu"]').parent().addClass('active');
            } else if (currentPath.includes('/Billing')) {
                $('[href="#billingSubmenu"]').parent().addClass('active');
            } else if (currentPath.includes('/Admin/SalesReport') || currentPath.includes('/Admin/OrderHistory')) {
                $('[href="#reportSubmenu"]').parent().addClass('active');
            }
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
