@{
    ViewData["Title"] = "Order History";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <h1 class="mb-4">
        <i class="fas fa-history"></i> Order History
    </h1>

    <div class="card">
        <div class="card-header">
            <i class="fas fa-receipt"></i> All Orders
        </div>
        <div class="card-body">
            @if (Model != null && Model.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Table</th>
                                <th>Date & Time</th>
                                <th>Status</th>
                                <th>Items</th>
                                <th>Total Amount</th>
                                <th>Bill Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>#@order.OrderID</strong>
                                    </td>
                                    <td>@order.Table?.TableNumber</td>
                                    <td>@order.OrderDate.ToString("dd MMM yyyy<br/>hh:mm tt")</td>
                                    <td>
                                        <span class="status-badge status-@order.OrderStatus.ToLower()">
                                            @order.OrderStatus
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary" onclick="toggleOrderItems(@order.OrderID)">
                                            <i class="fas fa-list"></i> @order.OrderItems.Count items
                                        </button>
                                    </td>
                                    <td><strong>@order.TotalAmount.ToString("C")</strong></td>
                                    <td>
                                        @if (order.Bill != null)
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check"></i> Billed
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">
                                                <i class="fas fa-clock"></i> Pending
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="/Order/Details/@order.OrderID" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            @if (order.Bill == null)
                                            {
                                                <a href="/Billing/GenerateBill?orderId=@order.OrderID" class="btn btn-sm btn-outline-success">
                                                    <i class="fas fa-file-invoice"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <a href="/Billing/Details/@order.Bill.BillID" class="btn btn-sm btn-outline-info">
                                                    <i class="fas fa-receipt"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                <tr id="orderItems-@order.OrderID" style="display: none;">
                                    <td colspan="8">
                                        <div class="p-3 bg-light">
                                            <h6>Order Items:</h6>
                                            <table class="table table-sm mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>Item</th>
                                                        <th>Quantity</th>
                                                        <th>Price</th>
                                                        <th>Subtotal</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var item in order.OrderItems)
                                                    {
                                                        <tr>
                                                            <td>@item.MenuItem?.ItemName</td>
                                                            <td>@item.Quantity</td>
                                                            <td>@item.Price.ToString("C")</td>
                                                            <td>@item.SubTotal.ToString("C")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="fas fa-receipt fa-3x text-muted mb-3"></i>
                    <p class="text-muted">No orders found.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleOrderItems(orderId) {
            var row = document.getElementById('orderItems-' + orderId);
            if (row.style.display === 'none') {
                row.style.display = 'table-row';
            } else {
                row.style.display = 'none';
            }
        }
    </script>
}
