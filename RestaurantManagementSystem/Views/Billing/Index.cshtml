@model IEnumerable<RestaurantManagementSystem.Models.Bill>
@{
    ViewData["Title"] = "Bills";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-file-invoice-dollar"></i> Billing Management
        </h1>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body text-center">
                    <h4>@(Model?.Count() ?? 0)</h4>
                    <p class="mb-0">Total Bills</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h4>@(Model?.Sum(b => b.FinalAmount).ToString("C") ?? "₹0.00")</h4>
                    <p class="mb-0">Total Revenue</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h4>@(Model?.Sum(b => b.Tax).ToString("C") ?? "₹0.00")</h4>
                    <p class="mb-0">Total Tax Collected</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body text-center">
                    <h4>@(Model?.Any() == true ? Model.Average(b => b.FinalAmount).ToString("C") : "₹0.00")</h4>
                    <p class="mb-0">Average Bill Amount</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <i class="fas fa-list"></i> All Bills
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Bill ID</th>
                                <th>Order ID</th>
                                <th>Table</th>
                                <th>Bill Date</th>
                                <th>Subtotal</th>
                                <th>Tax</th>
                                <th>Final Amount</th>
                                <th>Payment Method</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var bill in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>#@bill.BillID</strong>
                                    </td>
                                    <td>#@bill.OrderID</td>
                                    <td>@bill.Order?.Table?.TableNumber</td>
                                    <td>@bill.BillDate.ToString("dd MMM yyyy<br/>hh:mm tt")</td>
                                    <td>@bill.SubTotal.ToString("C")</td>
                                    <td>@bill.Tax.ToString("C")</td>
                                    <td><strong>@bill.FinalAmount.ToString("C")</strong></td>
                                    <td>
                                        <span class="badge bg-secondary">@bill.PaymentMethod</span>
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="/Billing/Details/@bill.BillID" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="/Billing/PrintBill/@bill.BillID" class="btn btn-sm btn-outline-info" target="_blank">
                                                <i class="fas fa-print"></i>
                                            </a>
                                            <a href="/Billing/Delete/@bill.BillID" class="btn btn-sm btn-outline-danger">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="fas fa-file-invoice-dollar fa-3x text-muted mb-3"></i>
                    <p class="text-muted">No bills found.</p>
                    <p class="text-muted">Generate bills from completed orders to see them here.</p>
                </div>
            }
        </div>
    </div>
</div>
