@model RestaurantManagementSystem.Models.Bill
@{
    ViewData["Title"] = "Generate Bill";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-file-invoice"></i> Generate Bill
        </h1>
        <a href="/Billing" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to Bills
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-receipt"></i> Order Details
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <td style="width: 150px;"><strong>Order ID:</strong></td>
                                    <td><h4>#@ViewBag.Order.OrderID</h4></td>
                                </tr>
                                <tr>
                                    <td><strong>Table:</strong></td>
                                    <td>@ViewBag.Order.Table?.TableNumber</td>
                                </tr>
                                <tr>
                                    <td><strong>Order Date:</strong></td>
                                    <td>@ViewBag.Order.OrderDate.ToString("dd MMM yyyy hh:mm tt")</td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <td style="width: 150px;"><strong>Order Status:</strong></td>
                                    <td>
                                        <span class="status-badge status-@ViewBag.Order.OrderStatus.ToLower()">
                                            @ViewBag.Order.OrderStatus
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>Items Count:</strong></td>
                                    <td>@ViewBag.Order.OrderItems.Count items</td>
                                </tr>
                                <tr>
                                    <td><strong>Subtotal:</strong></td>
                                    <td><h5>@ViewBag.Order.TotalAmount.ToString("C")</h5></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <div class="mt-4">
                        <h6>Order Items:</h6>
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Item Name</th>
                                        <th>Quantity</th>
                                        <th>Unit Price</th>
                                        <th>Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in ViewBag.Order.OrderItems)
                                    {
                                        <tr>
                                            <td>@item.MenuItem?.ItemName</td>
                                            <td>@item.Quantity</td>
                                            <td>@item.Price.ToString("C")</td>
                                            <td><strong>@item.SubTotal.ToString("C")</strong></td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="table-primary">
                                        <th colspan="3">Subtotal:</th>
                                        <th>@ViewBag.Order.TotalAmount.ToString("C")</th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-calculator"></i> Bill Calculation
                </div>
                <div class="card-body">
                    <form asp-action="GenerateBill" method="post">
                        <input type="hidden" asp-for="OrderID" />
                        <input type="hidden" asp-for="SubTotal" />
                        <input type="hidden" asp-for="Tax" />
                        <input type="hidden" asp-for="FinalAmount" />
                        
                        <div class="mb-3">
                            <label class="form-label">Subtotal:</label>
                            <input type="text" class="form-control" value="@Model.SubTotal.ToString("C")" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Tax (@ViewBag.TaxRate%):</label>
                            <input type="text" class="form-control" value="@Model.Tax.ToString("C")" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Final Amount:</label>
                            <input type="text" class="form-control" value="@Model.FinalAmount.ToString("C")" readonly />
                        </div>

                        <div class="mb-3">
                            <label asp-for="PaymentMethod" class="form-label">Payment Method</label>
                            <select asp-for="PaymentMethod" class="form-control">
                                <option value="Cash">Cash</option>
                                <option value="Card">Card</option>
                                <option value="Online">Online</option>
                            </select>
                            <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Bill Date:</label>
                            <input type="text" class="form-control" value="@DateTime.Now.ToString("dd MMM yyyy hh:mm tt")" readonly />
                        </div>

                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i>
                            <strong>Note:</strong> Generating this bill will mark the order as completed and free up the table.
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-check"></i> Generate Bill
                            </button>
                            <a href="/Order/Cancel/@ViewBag.Order.OrderID" class="btn btn-warning" onclick="return confirm('Are you sure you want to cancel this order? This will free up the table.')">
                                <i class="fas fa-times"></i> Cancel Order
                            </a>
                            <a href="/Billing" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Back to Bills
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
