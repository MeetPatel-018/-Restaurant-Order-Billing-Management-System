@model RestaurantManagementSystem.Models.Bill
@{
    ViewData["Title"] = "Delete Bill";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-trash"></i> Delete Bill
        </h1>
        <a href="/Billing" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card">
        <div class="card-header bg-danger text-white">
            <i class="fas fa-exclamation-triangle"></i> Confirm Deletion
        </div>
        <div class="card-body">
            <h3>Are you sure you want to delete this bill?</h3>

            <div class="row">
                <div class="col-md-6">
                    <table class="table table-borderless">
                        <tr>
                            <td style="width: 150px;"><strong>Bill ID:</strong></td>
                            <td>#@Model.BillID</td>
                        </tr>
                        <tr>
                            <td><strong>Order ID:</strong></td>
                            <td>#@Model.OrderID</td>
                        </tr>
                        <tr>
                            <td><strong>Table:</strong></td>
                            <td>@Model.Order?.Table?.TableNumber</td>
                        </tr>
                        <tr>
                            <td><strong>Bill Date:</strong></td>
                            <td>@Model.BillDate.ToString("dd MMM yyyy hh:mm tt")</td>
                        </tr>
                        <tr>
                            <td><strong>Payment Method:</strong></td>
                            <td>@Model.PaymentMethod</td>
                        </tr>
                        <tr>
                            <td><strong>Final Amount:</strong></td>
                            <td><h4 class="text-danger">@Model.FinalAmount.ToString("C")</h4></td>
                        </tr>
                    </table>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header">
                    <i class="fas fa-calculator"></i> Bill Breakdown
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <tr>
                            <td>Subtotal:</td>
                            <td>@Model.SubTotal.ToString("C")</td>
                        </tr>
                        <tr>
                            <td>Tax:</td>
                            <td>@Model.Tax.ToString("C")</td>
                        </tr>
                        <tr class="table-danger">
                            <td><strong>Total Amount:</strong></td>
                            <td><strong>@Model.FinalAmount.ToString("C")</strong></td>
                        </tr>
                    </table>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="BillID" />
                <div class="mt-3">
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Delete Bill
                    </button>
                    <a href="/Billing" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
