@model RestaurantManagementSystem.Models.MenuItem
@{
    ViewData["Title"] = "Delete Menu Item";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-trash"></i> Delete Menu Item
        </h1>
        <a href="/Menu" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card">
        <div class="card-header bg-danger text-white">
            <i class="fas fa-exclamation-triangle"></i> Confirm Deletion
        </div>
        <div class="card-body">
            <h3>Are you sure you want to delete this menu item?</h3>
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-circle"></i>
                <strong>Warning:</strong> This action cannot be undone.
            </div>

            <div class="row">
                <div class="col-md-6">
                    <table class="table table-borderless">
                        <tr>
                            <td style="width: 150px;"><strong>Item ID:</strong></td>
                            <td>@Model.ItemID</td>
                        </tr>
                        <tr>
                            <td><strong>Item Name:</strong></td>
                            <td>@Model.ItemName</td>
                        </tr>
                        <tr>
                            <td><strong>Category:</strong></td>
                            <td>@Model.Category?.CategoryName</td>
                        </tr>
                        <tr>
                            <td><strong>Price:</strong></td>
                            <td>@Model.Price.ToString("C")</td>
                        </tr>
                        <tr>
                            <td><strong>Status:</strong></td>
                            <td>
                                <span class="status-badge status-@Model.Status.ToLower()">
                                    @Model.Status
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Description:</strong></td>
                            <td>@(string.IsNullOrEmpty(Model.Description) ? "No description" : Model.Description)</td>
                        </tr>
                    </table>
                </div>
            </div>

            <form asp-action="DeleteConfirmed" method="post">
                <input type="hidden" asp-for="ItemID" />
                <div class="mt-3">
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Delete Menu Item
                    </button>
                    <a href="/Menu" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
