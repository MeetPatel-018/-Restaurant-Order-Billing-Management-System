@model IEnumerable<RestaurantManagementSystem.Models.MenuItem>
@{
    ViewData["Title"] = "Menu Items";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-hamburger"></i> Menu Items
        </h1>
        <a href="@Url.Action("Create", "Menu")" class="btn btn-teal">
            <i class="fas fa-plus"></i> Add New Item
        </a>
    </div>

    <div class="card">
        <div class="card-header">
            <i class="fas fa-list"></i> All Menu Items
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Item ID</th>
                                <th>Item Name</th>
                                <th>Category</th>
                                <th>Price</th>
                                <th>Status</th>
                                <th>Description</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.ItemID</td>
                                    <td>
                                        <strong>@item.ItemName</strong>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@item.Category?.CategoryName</span>
                                    </td>
                                    <td><strong>@item.Price.ToString("C")</strong></td>
                                    <td>
                                        <span class="status-badge status-@(item.Status == "Available" ? "available" : "not-available")">
                                            @item.Status
                                        </span>
                                    </td>
                                    <td>@(string.IsNullOrEmpty(item.Description) ? "-" : item.Description.Substring(0, Math.Min(item.Description.Length, 50)) + "...")</td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="/Menu/Details/@item.ItemID" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="/Menu/Edit/@item.ItemID" class="btn btn-sm btn-outline-warning">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <form asp-action="ToggleStatus" asp-route-id="@item.ItemID" method="post" style="display: inline;">
                                                <button type="submit" class="btn btn-sm @(item.Status == "Available" ? "btn-outline-warning" : "btn-outline-success")">
                                                    <i class="fas fa-toggle-on"></i>
                                                </button>
                                            </form>
                                            <a href="/Menu/Delete/@item.ItemID" class="btn btn-sm btn-outline-danger">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="fas fa-hamburger fa-3x text-muted mb-3"></i>
                    <p class="text-muted">No menu items found.</p>
                    <a href="/Menu/Create" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Add First Menu Item
                    </a>
                </div>
            }
        </div>
    </div>
</div>
